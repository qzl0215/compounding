{
  "name": "compounding-ai-operating-system",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "pnpm --filter studio dev",
    "build": "pnpm --filter studio build",
    "lint": "pnpm --filter studio lint",
    "test": "pnpm --filter studio test && python3 -m unittest discover -s tests -p 'test_*.py'",
    "bootstrap:scaffold": "python3 scripts/init_project_compounding.py scaffold --config bootstrap/project_brief.yaml --target .",
    "bootstrap:audit": "python3 scripts/init_project_compounding.py audit --config bootstrap/project_brief.yaml --target .",
    "bootstrap:propose": "python3 scripts/init_project_compounding.py propose --config bootstrap/project_brief.yaml --target . --prompt-file output/manual_prompt.md",
    "preflight": "python3 scripts/pre_mutation_check.py",
    "ai:scan-health": "node --experimental-strip-types scripts/ai/scan-code-health.ts",
    "ai:scan-health:strict": "node --experimental-strip-types scripts/ai/scan-code-health.ts --strict",
    "ai:generate-index": "node --experimental-strip-types scripts/ai/generate-module-index.ts",
    "ai:generate-experience-index": "node --experimental-strip-types scripts/ai/generate-experience-index.ts",
    "ai:generate-assets": "node --experimental-strip-types scripts/ai/generate-asset-maintenance.ts",
    "ai:build-context": "node --experimental-strip-types scripts/ai/build-context.ts tasks/queue/task-002-ui-task-pm-and-doc-localization.md",
    "ai:create-task": "node --experimental-strip-types scripts/ai/create-task.ts",
    "ai:validate-trace": "node --experimental-strip-types scripts/ai/validate-change-trace.ts",
    "ai:validate-task-git": "node --experimental-strip-types scripts/ai/validate-task-git-link.ts",
    "ai:validate-assets": "node --experimental-strip-types scripts/ai/validate-knowledge-assets.ts",
    "validate:static": "pnpm lint && pnpm ai:scan-health && pnpm ai:validate-trace && pnpm ai:validate-task-git && pnpm ai:validate-assets",
    "validate:static:strict": "pnpm lint && pnpm ai:scan-health:strict && pnpm ai:validate-trace && pnpm ai:validate-task-git && pnpm ai:validate-assets",
    "validate:build": "pnpm test && pnpm build && pnpm bootstrap:audit",
    "validate:runtime:dev": "pnpm preview:check",
    "validate:runtime:prod": "pnpm prod:check",
    "validate:ai-output": "node --experimental-strip-types scripts/ai/validate-ai-output.ts",
    "validate:pre-landing": "node scripts/ai/pre-landing-checklist.js",
    "validate:release": "pnpm validate:static && pnpm validate:build",
    "release:prepare": "node --experimental-strip-types scripts/release/prepare-release.ts --ref main",
    "release:switch": "node --experimental-strip-types scripts/release/switch-release.ts",
    "release:rollback": "node --experimental-strip-types scripts/release/rollback-release.ts",
    "release:summarize": "node --experimental-strip-types scripts/release/summarize-release.ts",
    "preview:start": "node --experimental-strip-types scripts/local-runtime/start-preview.ts",
    "preview:stop": "node --experimental-strip-types scripts/local-runtime/stop-preview.ts",
    "preview:status": "node --experimental-strip-types scripts/local-runtime/status-preview.ts",
    "preview:check": "node --experimental-strip-types scripts/local-runtime/check-preview.ts",
    "prod:start": "node --experimental-strip-types scripts/local-runtime/start-prod.ts",
    "prod:stop": "node --experimental-strip-types scripts/local-runtime/stop-prod.ts",
    "prod:status": "node --experimental-strip-types scripts/local-runtime/status-prod.ts",
    "prod:check": "node --experimental-strip-types scripts/local-runtime/check-prod.ts"
  }
}
