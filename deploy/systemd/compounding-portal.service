[Unit]
Description=Compounding AI OS Portal
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/compounding-ai-os/current/apps/studio
Environment=NODE_ENV=production
EnvironmentFile=-/srv/compounding-ai-os/shared/portal.env
ExecStart=/usr/bin/env pnpm start --hostname 127.0.0.1 --port 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
